{
  "name": "@gemdoq/codi",
  "version": "0.1.3",
  "description": "AI coding agent for your terminal. Read, write, search, and execute — all through natural language.",
  "type": "module",
  "bin": {
    "codi": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gemdoq/codi.git"
  },
  "homepage": "https://github.com/gemdoq/codi",
  "bugs": {
    "url": "https://github.com/gemdoq/codi/issues"
  },
  "author": "gemdoq",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "terminal",
    "cli",
    "llm",
    "gemini",
    "openai",
    "anthropic",
    "claude",
    "copilot",
    "code-assistant"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clack/prompts": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "cli-highlight": "^2.1.11",
    "diff": "^8.0.3",
    "external-editor": "^3.1.0",
    "globby": "^16.1.1",
    "js-tiktoken": "^1.0.21",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ollama": "^0.6.3",
    "openai": "^6.25.0",
    "ora": "^9.3.0",
    "pdf-parse": "^2.4.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^25.3.3",
    "@types/pdf-parse": "^1.1.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
